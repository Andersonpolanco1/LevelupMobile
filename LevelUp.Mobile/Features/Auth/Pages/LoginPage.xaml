<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LevelUp.Mobile.Features.Auth.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Dark=#0B0B0C, Light=#F7F7F9}">

    <Grid>
        <Grid
            IsVisible="{Binding IsNotLoggedIn}"
            RowDefinitions="0.6*,0.4*">

            <VerticalStackLayout
                Grid.Row="0"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="20"
                Padding="40,0">

                <Image
                    Source="logo_splash"
                    HeightRequest="100"
                    WidthRequest="100"
                    HorizontalOptions="Center" />

                <Label
                    Text="LevelUp"
                    FontSize="40"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#18181B}" />

                <Label
                    Text="Track. Progress. Dominate."
                    FontSize="15"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Dark=#A1A1AA, Light=#71717A}" />

            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Row="1"
                Padding="32,0,32,60"
                Spacing="16"
                VerticalOptions="End">

                <Border
                    BackgroundColor="{AppThemeBinding Dark=#232327, Light=#FFFFFF}"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Dark=#2A2A2E, Light=#E4E4E7}"
                    StrokeShape="RoundRectangle 14"
                    IsEnabled="{Binding IsNotBusy}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LoginWithGoogleCommand}" />
                    </Border.GestureRecognizers>
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12"
                        Padding="20,16">
                        <Image
                            Grid.Column="0"
                            Source="google_logo.png"
                            HeightRequest="24"
                            WidthRequest="24"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="Continue with Google"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#18181B}" />
                    </Grid>
                </Border>

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#FF7A00"
                    HorizontalOptions="Center" />

                <Label
                    Text="By continuing, you agree to our Terms of Service and Privacy Policy."
                    FontSize="11"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    TextColor="{AppThemeBinding Dark=#52525B, Light=#A1A1AA}" />

            </VerticalStackLayout>
        </Grid>

        <VerticalStackLayout
            IsVisible="{Binding IsLoggedIn}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="20"
            Padding="32,0">

            <Border
                WidthRequest="90"
                HeightRequest="90"
                StrokeShape="RoundRectangle 999"
                StrokeThickness="3"
                Stroke="#FF7A00"
                HorizontalOptions="Center">
                <Image
                    Source="{Binding ProfilePhotoUrl}"
                    Aspect="AspectFill" />
            </Border>

            <Label
                Text="{Binding UserName}"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#18181B}" />

            <Label
                Text="{Binding UserEmail}"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Dark=#A1A1AA, Light=#71717A}" />

            <Border
                BackgroundColor="Transparent"
                StrokeThickness="1.5"
                Stroke="#FF7A00"
                StrokeShape="RoundRectangle 12"
                Padding="0"
                HorizontalOptions="Fill">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>
                <Label
                    Text="Sign out"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="#FF7A00"
                    HorizontalOptions="Center"
                    Padding="0,14" />
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>