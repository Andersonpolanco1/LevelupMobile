<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LevelUp.Mobile.Features.Auth.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid BackgroundColor="{AppThemeBinding Dark=#121212, Light=#F2F2F7}">

        <!-- ═══════════════════════════════════════ -->
        <!--  ESTADO: NO AUTENTICADO                  -->
        <!-- ═══════════════════════════════════════ -->
        <VerticalStackLayout
            IsVisible="{Binding IsNotLoggedIn}"
            VerticalOptions="Fill"
            Spacing="0">

            <!-- Parte superior: Logo y branding (60% de la pantalla) -->
            <VerticalStackLayout
                VerticalOptions="FillAndExpand"
                HorizontalOptions="Center"
                Spacing="20"
                Padding="40,80,40,40">

                <!-- Logo -->
                <Image
                    Source="logo.png"
                    HeightRequest="100"
                    WidthRequest="100"
                    HorizontalOptions="Center" />

                <!-- Nombre -->
                <Label
                    Text="LevelUp"
                    FontSize="40"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#1C1C1E}" />

                <!-- Tagline -->
                <Label
                    Text="Track. Progress. Dominate."
                    FontSize="15"
                    HorizontalOptions="Center"
                    TextColor="{AppThemeBinding Dark=#A0A0A0, Light=#6C6C70}" />

            </VerticalStackLayout>

            <!-- Parte inferior: Botón de login -->
            <VerticalStackLayout
                Padding="32,0,32,60"
                Spacing="16"
                VerticalOptions="End">

                <!-- Botón Google -->
                <Border
                    BackgroundColor="{AppThemeBinding Dark=#1E2022, Light=#FFFFFF}"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Dark=#2C2F33, Light=#E5E5EA}"
                    StrokeShape="RoundRectangle 14"
                    IsEnabled="{Binding IsNotBusy}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LoginWithGoogleCommand}" />
                    </Border.GestureRecognizers>
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12"
                        Padding="20,16">
                        <Image
                            Grid.Column="0"
                            Source="google_logo.png"
                            HeightRequest="24"
                            WidthRequest="24"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="Continue with Google"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#1C1C1E}" />
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#FF4500"
                    HorizontalOptions="Center" />

                <!-- Términos -->
                <Label
                    Text="By continuing, you agree to our Terms of Service and Privacy Policy."
                    FontSize="11"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    TextColor="{AppThemeBinding Dark=#606060, Light=#AEAEB2}" />

            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--  ESTADO: AUTENTICADO (vista de logout)   -->
        <!-- ═══════════════════════════════════════ -->
        <VerticalStackLayout
            IsVisible="{Binding IsLoggedIn}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="20"
            Padding="32,0">

            <!-- Avatar -->
            <Border
                WidthRequest="90"
                HeightRequest="90"
                StrokeShape="RoundRectangle 999"
                StrokeThickness="3"
                Stroke="#FF4500"
                HorizontalOptions="Center">
                <Image
                    Source="{Binding ProfilePhotoUrl}"
                    Aspect="AspectFill" />
            </Border>

            <!-- Nombre y email -->
            <Label
                Text="{Binding UserName}"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Dark=#FFFFFF, Light=#1C1C1E}" />

            <Label
                Text="{Binding UserEmail}"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Dark=#A0A0A0, Light=#6C6C70}" />

            <!-- Botón logout -->
            <Border
                BackgroundColor="Transparent"
                StrokeThickness="1.5"
                Stroke="#FF4500"
                StrokeShape="RoundRectangle 12"
                Padding="0"
                HorizontalOptions="Fill">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>
                <Label
                    Text="Sign out"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="#FF4500"
                    HorizontalOptions="Center"
                    Padding="0,14" />
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
