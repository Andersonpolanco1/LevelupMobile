<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LevelUp.Mobile.Features.Plans.Pages.CreatePlanPage"
             Title="CreatePlanPage">
    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
        Text="Crear Plan Semanal"
        FontSize="24"
        FontAttributes="Bold"/>

        <Entry
        Placeholder="Nombre del plan"
        Text="{Binding Name}" />

        <Editor
        Placeholder="Notas del plan (opcional)"
        HeightRequest="120"
        Text="{Binding Notes}" />

        <Button
        Text="Crear Plan"
        Command="{Binding CreatePlanCommand}"
        HeightRequest="50"/>

    </VerticalStackLayout>
</ContentPage>