<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
             xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
             xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
             x:Class="LevelUp.Mobile.Features.Plans.Pages.CreatePlanPage"
             x:DataType="vm:CreatePlanViewModel"
             Title="Nuevo Plan">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="4">
                <Label Text="{local:Localize NewPlan}"
                       Style="{StaticResource TitleLabel}" />
                <Label Text="{local:Localize NewPlanSubtitle}"
                       Style="{StaticResource BodyLabel}" />
            </VerticalStackLayout>

            <!-- FORMULARIO -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="16">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Localize PlanName}"
                               Style="{StaticResource CaptionLabel}" />
                        <Entry Placeholder="{local:Localize PlanNamePlaceholder}"
                               Text="{Binding Name}" />
                        <Label Text="{Binding NameError}"
                               TextColor="{StaticResource Error}"
                               FontSize="12"
                               IsVisible="{Binding NameError, Converter={StaticResource IsNotNullConverter}}"/>
                    </VerticalStackLayout>

                    <BoxView Style="{StaticResource Divider}" />

                    <!-- Notas -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{local:Localize NotesOptional}"
                               Style="{StaticResource CaptionLabel}" />
                        <Editor Placeholder="{local:Localize NotesPlaceholder}"
                                Text="{Binding Notes}"
                                HeightRequest="120"
                                TextColor="{AppThemeBinding 
                                    Light={StaticResource TextPrimaryLight}, 
                                    Dark={StaticResource TextPrimaryDark}}"
                                PlaceholderColor="{AppThemeBinding 
                                    Light={StaticResource TextDisabledLight}, 
                                    Dark={StaticResource TextDisabledDark}}"
                                FontSize="14" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- BOTÓN CREAR -->
            <Button Text="{local:Localize CreatePlan}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreatePlanCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>