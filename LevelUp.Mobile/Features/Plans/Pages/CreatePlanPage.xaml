<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
             xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
             x:Class="LevelUp.Mobile.Features.Plans.Pages.CreatePlanPage"
             x:DataType="vm:CreatePlanViewModel"
             Title="Nuevo Plan">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Nuevo plan"
                       Style="{StaticResource TitleLabel}" />
                <Label Text="Define el nombre y las notas de tu plan semanal"
                       Style="{StaticResource BodyLabel}" />
            </VerticalStackLayout>

            <!-- ERROR GENERAL (solo errores de API sin campo específico) -->
            <Border Style="{StaticResource CardBorder}"
                    BackgroundColor="{StaticResource Error}"
                    IsVisible="{Binding HasError}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           TextColor="White"
                           FontSize="14"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="{x:Static constants:FA.Xmark}"
                           FontFamily="FASolid"
                           TextColor="White"
                           FontSize="14"
                           Margin="8,0,0,0"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearErrorCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- FORMULARIO -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="16">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre del plan"
                               Style="{StaticResource CaptionLabel}" />
                        <Entry Placeholder="Ej. Fuerza 5 días"
                               Text="{Binding Name}" />
                        <Label Text="{Binding NameError}"
                               TextColor="{StaticResource Error}"
                               FontSize="12"
                               IsVisible="{Binding NameError, Converter={StaticResource IsNotNullConverter}}"/>
                    </VerticalStackLayout>

                    <BoxView Style="{StaticResource Divider}" />

                    <!-- Notas -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Notas (opcional)"
                               Style="{StaticResource CaptionLabel}" />
                        <Editor Placeholder="Descripción, objetivos, notas..."
                                Text="{Binding Notes}"
                                HeightRequest="120"
                                TextColor="{AppThemeBinding 
                                    Light={StaticResource TextPrimaryLight}, 
                                    Dark={StaticResource TextPrimaryDark}}"
                                PlaceholderColor="{AppThemeBinding 
                                    Light={StaticResource TextDisabledLight}, 
                                    Dark={StaticResource TextDisabledDark}}"
                                FontSize="14" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- BOTÓN CREAR -->
            <Button Text="Crear plan"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreatePlanCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>