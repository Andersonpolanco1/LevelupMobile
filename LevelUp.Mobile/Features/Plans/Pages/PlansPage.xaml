<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Core.Entities"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    x:Class="LevelUp.Mobile.Features.Plans.Pages.PlansPage"
    x:DataType="vm:PlansViewModel"
    Title="Plans">

    <Grid Padding="20" RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Margin="0,0,0,16">

            <VerticalStackLayout Spacing="4">
                <Label Text="{local:Localize MyPlans}"
                       Style="{StaticResource TitleLabel}"/>
                <Label Text="{local:Localize ManageWeeklyPlans}"
                       Style="{StaticResource BodyLabel}"/>
            </VerticalStackLayout>

            <!-- Cruz naranja plana, sin círculo ni borde -->
            <Label Grid.Column="1"
                   Text="{x:Static constants:FA.Plus}"
                   FontFamily="FASolid"
                   FontSize="24"
                   TextColor="{StaticResource Primary}"
                   VerticalOptions="Center"
                   HorizontalOptions="End">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CreatePlanCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- LISTA DE PLANES -->
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Plans}"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{x:Static constants:FA.CalendarDays}"
                           FontFamily="FASolid" FontSize="40"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize NoPlansYet}"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize CreateFirstPlan}"
                           Style="{StaticResource BodyLabel}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WeeklyPlan">
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource SubtitleLabel}"/>

                                <!-- Días más visibles con TextSecondary -->
                                <Label Text="{Binding DaysText}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding
                                           Light={StaticResource TextSecondaryLight},
                                           Dark={StaticResource TextSecondaryDark}}"/>

                                <Label Text="{local:Localize Active}"
                                       TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       IsVisible="{Binding IsActive}"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{x:Static constants:FA.AngleRight}"
                                   FontFamily="FASolid" FontSize="18"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource TextDisabledLight},
                                       Dark={StaticResource TextDisabledDark}}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                    Path=BindingContext.OpenPlanCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>