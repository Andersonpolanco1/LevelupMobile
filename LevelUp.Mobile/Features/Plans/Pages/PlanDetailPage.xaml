<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Features.Plans.Models"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    x:Class="LevelUp.Mobile.Features.Plans.Pages.PlanDetailPage"
    x:DataType="vm:PlanDetailViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Padding="20,56,20,20"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">

            <Grid Grid.Row="0"
                  ColumnDefinitions="40,*,40"
                  Margin="0,0,0,20">

                <Label Grid.Column="0"
                       Text="{x:Static constants:FA.AngleLeft}"
                       FontFamily="FASolid" FontSize="22"
                       TextColor="{StaticResource Primary}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1"
                       Text="{local:Localize PlanDetailTitle}"
                       Style="{StaticResource SubtitleLabel}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <Label Grid.Column="2"
                       Text="{x:Static constants:FA.Gear}"
                       FontFamily="FASolid" FontSize="22"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding
                           Light={StaticResource TextSecondaryLight},
                           Dark={StaticResource TextSecondaryDark}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditPlanCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="{Binding Plan.Name}"
                       Style="{StaticResource TitleLabel}"
                       LineBreakMode="TailTruncation"
                       VerticalOptions="Center"/>

                <Border Grid.Row="0" Grid.Column="1"
                        Padding="10,5" VerticalOptions="Center" Margin="8,4,0,0"
                        IsVisible="{Binding Plan.IsActive}"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#DCFCE7, Dark=#14321C}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="{local:Localize Active}"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource Success}"/>
                </Border>

                <Label Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding Plan.Notes}"
                       Style="{StaticResource BodyLabel}"
                       Margin="0,6,0,0"
                       IsVisible="{Binding Plan.Notes,
                           Converter={StaticResource IsNotNullConverter}}"/>

                <FlexLayout Grid.Row="2" Grid.ColumnSpan="2"
                            Wrap="Wrap" Direction="Row"
                            Margin="0,12,0,0"
                            BindableLayout.ItemsSource="{Binding Plan.DaysOfWeekShortName}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Padding="10,5" Margin="0,0,6,4"
                                    StrokeThickness="1"
                                    BackgroundColor="{AppThemeBinding
                                        Light={StaticResource SurfaceElevatedLight},
                                        Dark={StaticResource SurfaceElevatedDark}}"
                                    Stroke="{AppThemeBinding
                                        Light={StaticResource DividerLight},
                                        Dark={StaticResource DividerDark}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding .}"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding
                                           Light={StaticResource TextSecondaryLight},
                                           Dark={StaticResource TextSecondaryDark}}"/>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </Grid>

            <BoxView Grid.RowSpan="2" Style="{StaticResource Divider}" VerticalOptions="End"/>
        </Grid>

        <!-- ── DÍAS ── -->
        <ScrollView Grid.Row="1" Padding="20,20,20,8">
            <VerticalStackLayout Spacing="0">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                    Color="{StaticResource Primary}"
                    HorizontalOptions="Center" Margin="0,32,0,0"/>

                <VerticalStackLayout
                    Spacing="0"
                    IsVisible="{Binding IsBusy,
                        Converter={StaticResource InvertedBoolConverter}}">

                    <Label Text="{local:Localize DaysOfPlan}"
                           Style="{StaticResource CaptionLabel}"
                           FontAttributes="Bold" CharacterSpacing="2"
                           Margin="0,0,0,12"/>

                    <!-- Empty state -->
                    <VerticalStackLayout
                        IsVisible="{Binding Days.Count,
                            Converter={StaticResource IntEqualsZeroBoolConverter}}"
                        HorizontalOptions="Center"
                        Spacing="8" Margin="0,48,0,0">
                        <Label Text="{x:Static constants:FA.CalendarDays}"
                               FontFamily="FASolid" FontSize="40"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"/>
                        <Label Text="{local:Localize NoDaysConfigured}"
                               Style="{StaticResource SubtitleLabel}"
                               HorizontalOptions="Center"/>
                        <Label Text="{local:Localize NoDaysConfiguredSub}"
                               Style="{StaticResource BodyLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Day cards -->
                    <VerticalStackLayout
                        Spacing="10"
                        BindableLayout.ItemsSource="{Binding Days}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:DayWithCount">
                                <Border Style="{StaticResource CardBorder}" Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.OpenDayCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="4,16,*,Auto" Padding="0,14,16,14">
                                        <BoxView Grid.Column="0"
                                                 WidthRequest="4"
                                                 BackgroundColor="{StaticResource Primary}"
                                                 VerticalOptions="Fill"/>
                                        <VerticalStackLayout Grid.Column="2" Spacing="3">
                                            <Label Text="{Binding DayName}"
                                                   Style="{StaticResource SubtitleLabel}"
                                                   FontSize="16"/>
                                            <Label Text="{Binding Day.Notes}"
                                                   Style="{StaticResource BodyLabel}"
                                                   IsVisible="{Binding Day.Notes,
                                                       Converter={StaticResource IsNotNullConverter}}"/>
                                            <HorizontalStackLayout Spacing="5" Margin="0,2,0,0">
                                                <Label Text="{x:Static constants:FA.Dumbbell}"
                                                       FontFamily="FASolid" FontSize="11"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding ExercisesText}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="3"
                                               Text="{x:Static constants:FA.AngleRight}"
                                               FontFamily="FASolid" FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextDisabledLight},
                                                   Dark={StaticResource TextDisabledDark}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="16" Color="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── ACTION BAR ── -->
        <Grid Grid.Row="2"
              Padding="20,12,20,36"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}"
              IsVisible="{Binding IsNotActive}">
            <BoxView Style="{StaticResource Divider}"
                     VerticalOptions="Start" Margin="0,-12,0,0"/>
            <Button Text="{local:Localize ActivatePlan}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ActivatePlanCommand}"
                    Margin="0,12,0,0"/>
        </Grid>

    </Grid>
</ContentPage>