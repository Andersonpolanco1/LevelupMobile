<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Features.Plans.Models"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    x:Class="LevelUp.Mobile.Features.Plans.Pages.PlanEditPage"
    x:DataType="vm:PlanEditViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="40,*"
              Padding="20,56,20,20"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">

            <Label Grid.Column="0"
                   Text="{x:Static constants:FA.AngleLeft}"
                   FontFamily="FASolid" FontSize="22"
                   TextColor="{StaticResource Primary}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Grid.Column="1"
                   Text="{local:Localize ConfigurePlan}"
                   Style="{StaticResource SubtitleLabel}"
                   HorizontalOptions="Center" VerticalOptions="Center"/>

            <BoxView Grid.ColumnSpan="2"
                     Style="{StaticResource Divider}"
                     VerticalOptions="End"/>
        </Grid>

        <!-- ── CONTENIDO ── -->
        <ScrollView Grid.Row="1" Padding="20,20,20,40">
            <VerticalStackLayout Spacing="24">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                    Color="{StaticResource Primary}"
                    HorizontalOptions="Center" Margin="0,32,0,0"/>

                <VerticalStackLayout
                    Spacing="24"
                    IsVisible="{Binding IsBusy,
                        Converter={StaticResource InvertedBoolConverter}}">

                    <!-- ── Info del plan ── -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{local:Localize PlanInfoSection}"
                               Style="{StaticResource CaptionLabel}"
                               FontAttributes="Bold" CharacterSpacing="2"/>

                        <Border Padding="12,0" StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding
                                    Light={StaticResource SurfaceLight},
                                    Dark={StaticResource SurfaceElevatedDark}}"
                                Stroke="{AppThemeBinding
                                    Light={StaticResource DividerLight},
                                    Dark={StaticResource DividerDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry Text="{Binding PlanName}"
                                   Placeholder="{local:Localize PlanNamePlaceholder}"/>
                        </Border>

                        <Border Padding="12,8" StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding
                                    Light={StaticResource SurfaceLight},
                                    Dark={StaticResource SurfaceElevatedDark}}"
                                Stroke="{AppThemeBinding
                                    Light={StaticResource DividerLight},
                                    Dark={StaticResource DividerDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding PlanNotes}"
                                    Placeholder="{local:Localize PlanNotesPlaceholder}"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="80"/>
                        </Border>

                        <Button Text="{local:Localize SaveChanges}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SavePlanInfoCommand}"/>
                    </VerticalStackLayout>

                    <!-- ── Días de entrenamiento ── -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{local:Localize TrainingDays}"
                               Style="{StaticResource CaptionLabel}"
                               FontAttributes="Bold" CharacterSpacing="2"/>

                        <Label Text="{local:Localize TrainingDaysHint}"
                               Style="{StaticResource BodyLabel}"
                               Margin="0,0,0,4"/>

                        <VerticalStackLayout
                            Spacing="8"
                            BindableLayout.ItemsSource="{Binding DayItems}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:DayEditItem">
                                    <Border Style="{StaticResource CardBorder}" Padding="0">
                                        <VerticalStackLayout Spacing="0">

                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                  ColumnSpacing="12"
                                                  Padding="16,12,16,12">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                            Path=BindingContext.TapDayCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Grid.GestureRecognizers>

                                                <Switch Grid.Column="0"
                                                        IsToggled="{Binding IsEnabled}"
                                                        OnColor="{StaticResource Primary}"
                                                        ThumbColor="White"
                                                        VerticalOptions="Center"
                                                        InputTransparent="True"/>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding DisplayName}"
                                                           Style="{StaticResource SubtitleLabel}"
                                                           FontSize="16"/>
                                                    <HorizontalStackLayout
                                                        Spacing="4"
                                                        IsVisible="{Binding IsEnabled}">
                                                        <Label Text="{x:Static constants:FA.Dumbbell}"
                                                               FontFamily="FASolid" FontSize="11"
                                                               TextColor="{AppThemeBinding
                                                                   Light={StaticResource TextSecondaryLight},
                                                                   Dark={StaticResource TextSecondaryDark}}"
                                                               VerticalOptions="Center"/>
                                                        <Label Text="{Binding ExercisesText}"
                                                               FontSize="12"
                                                               TextColor="{AppThemeBinding
                                                                   Light={StaticResource TextSecondaryLight},
                                                                   Dark={StaticResource TextSecondaryDark}}"
                                                               VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <Border Grid.Column="2"
                                                        Padding="6,3" StrokeThickness="0"
                                                        BackgroundColor="#3DF59E0B"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding ExerciseCount,
                                                            Converter={StaticResource IntGreaterThanZeroBoolConverter}}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{x:Static constants:FA.TriangleExclamation}"
                                                           FontFamily="FASolid" FontSize="13"
                                                           TextColor="{StaticResource Warning}"/>
                                                </Border>

                                                <Label Grid.Column="3"
                                                       Text="{x:Static constants:FA.AngleUp}"
                                                       FontFamily="FASolid" FontSize="14"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding IsExpandedNotes}"
                                                       TextColor="{AppThemeBinding
                                                           Light={StaticResource TextDisabledLight},
                                                           Dark={StaticResource TextDisabledDark}}">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                Path=BindingContext.ToggleNotesCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Label.GestureRecognizers>
                                                </Label>

                                                <Label Grid.Column="3"
                                                       Text="{x:Static constants:FA.AngleDown}"
                                                       FontFamily="FASolid" FontSize="14"
                                                       VerticalOptions="Center"
                                                       TextColor="{AppThemeBinding
                                                           Light={StaticResource TextDisabledLight},
                                                           Dark={StaticResource TextDisabledDark}}">
                                                    <Label.IsVisible>
                                                        <MultiBinding Converter="{StaticResource AllTrueBoolConverter}">
                                                            <Binding Path="IsEnabled"/>
                                                            <Binding Path="IsExpandedNotes"
                                                                     Converter="{StaticResource InvertedBoolConverter}"/>
                                                        </MultiBinding>
                                                    </Label.IsVisible>
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                Path=BindingContext.ToggleNotesCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>

                                            <VerticalStackLayout
                                                IsVisible="{Binding IsExpandedNotes}"
                                                Spacing="10"
                                                Padding="16,0,16,14">
                                                <BoxView Style="{StaticResource Divider}" Margin="0,0,0,4"/>
                                                <Label Text="{local:Localize DayNotesLabel}"
                                                       Style="{StaticResource CaptionLabel}"
                                                       FontAttributes="Bold"/>
                                                <Border Padding="12,0" StrokeThickness="1"
                                                        BackgroundColor="{AppThemeBinding
                                                            Light={StaticResource SurfaceElevatedLight},
                                                            Dark={StaticResource SurfaceElevatedDark}}"
                                                        Stroke="{AppThemeBinding
                                                            Light={StaticResource DividerLight},
                                                            Dark={StaticResource DividerDark}}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="12"/>
                                                    </Border.StrokeShape>
                                                    <Entry Text="{Binding Notes}"
                                                           Placeholder="{local:Localize DayNotesPlaceholder}"
                                                           ReturnType="Done"/>
                                                </Border>
                                                <Button Text="{local:Localize SaveNotes}"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                            Path=BindingContext.SaveDayNotesCommand}"
                                                        CommandParameter="{Binding .}"
                                                        HorizontalOptions="End"
                                                        WidthRequest="160"/>
                                            </VerticalStackLayout>

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- ── Zona de peligro ── -->
                    <VerticalStackLayout Spacing="12" Margin="0,16,0,0">
                        <BoxView Style="{StaticResource Divider}"/>
                        <Label Text="{local:Localize DangerZone}"
                               Style="{StaticResource CaptionLabel}"
                               FontAttributes="Bold" CharacterSpacing="2"
                               TextColor="{StaticResource Error}"/>
                        <Label Text="{local:Localize DeletePlanWarning}"
                               Style="{StaticResource BodyLabel}"/>
                        <Label Text="{local:Localize DeletePlan}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Error}"
                               Margin="0,4,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DeletePlanCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>