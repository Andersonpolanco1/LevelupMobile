<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Plans.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Features.Plans.Models"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    xmlns:controls="clr-namespace:LevelUp.Mobile.Shared.Controls"
    x:Class="LevelUp.Mobile.Features.Plans.Pages.PlanDayDetailPage"
    x:DataType="vm:PlanDayDetailViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0"
      RowDefinitions="Auto,Auto"
      Padding="20,44,20,12"
      BackgroundColor="{AppThemeBinding
          Light={StaticResource SurfaceLight},
          Dark={StaticResource SurfaceDark}}">

            <!-- Top nav -->
            <Grid Grid.Row="0"
          ColumnDefinitions="40,*,40"
          Margin="0,0,0,10">

                <Label Grid.Column="0"
                       Text="{x:Static constants:FA.AngleLeft}"
                       FontFamily="FASolid" FontSize="22"
                       TextColor="{StaticResource Primary}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1"
                       Text="{Binding DayName}"
                       Style="{StaticResource SubtitleLabel}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <Label Grid.Column="2"
                       Text="{x:Static constants:FA.PenToSquare}"
                       FontFamily="FASolid" FontSize="18"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding
                           Light={StaticResource TextSecondaryLight},
                           Dark={StaticResource TextSecondaryDark}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditNotesCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Day info row -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">

                <Label Grid.Column="0"
                       Text="{Binding Day.Notes}"
                       Style="{StaticResource BodyLabel}"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation"
                       IsVisible="{Binding Day.Notes,
                           Converter={StaticResource IsNotNullConverter}}"/>

                <Border Grid.Column="1"
                        Padding="10,5"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        BackgroundColor="{AppThemeBinding
                            Light={StaticResource SurfaceElevatedLight},
                            Dark={StaticResource SurfaceElevatedDark}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding ExerciseCount}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center"/>
                        <Label Text="{local:Localize ExercisesShort}"
                               FontSize="12"
                               TextColor="{AppThemeBinding
                                   Light={StaticResource TextSecondaryLight},
                                   Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <BoxView Grid.RowSpan="2" Style="{StaticResource Divider}" VerticalOptions="End"/>
        </Grid>

        <!-- ── EXERCISES LIST ── -->
        <ScrollView Grid.Row="1" Padding="20,16,20,8">
            <VerticalStackLayout Spacing="0">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource Primary}"
                    HorizontalOptions="Center"
                    Margin="0,48,0,0"/>

                <VerticalStackLayout
                    Spacing="0"
                    IsVisible="{Binding IsBusy,
                        Converter={StaticResource InvertedBoolConverter}}">

                    <!-- Empty state -->
                    <VerticalStackLayout
                        IsVisible="{Binding HasExercises,
                            Converter={StaticResource InvertedBoolConverter}}"
                        HorizontalOptions="Center"
                        Spacing="10"
                        Margin="0,60,0,0">
                        <Label Text="{x:Static constants:FA.Dumbbell}"
                               FontFamily="FASolid" FontSize="48"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"/>
                        <Label Text="{local:Localize NoExercisesYet}"
                               Style="{StaticResource SubtitleLabel}"
                               HorizontalOptions="Center"/>
                        <Label Text="{local:Localize AddFirstExercise}"
                               Style="{StaticResource BodyLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="24,0"/>
                    </VerticalStackLayout>

                    <!-- Grid agrupado por músculo -->
                    <CollectionView
                        ItemsSource="{Binding ExerciseGroups}"
                        IsGrouped="True"
                        SelectionMode="None"
                        IsVisible="{Binding HasExercises}">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout
                                Orientation="Vertical"
                                Span="2"
                                HorizontalItemSpacing="10"
                                VerticalItemSpacing="0"/>
                        </CollectionView.ItemsLayout>

                        <!-- Header: grupo muscular -->
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="models:PlanExerciseGroup">
                                <Label Text="{Binding MuscleGroupName}"
                                       FontSize="12" FontAttributes="Bold"
                                       CharacterSpacing="1.2"
                                       Margin="2,12,0,6"
                                       TextColor="{AppThemeBinding
                                           Light={StaticResource TextDisabledLight},
                                           Dark={StaticResource TextDisabledDark}}"/>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <!-- Card de ejercicio -->
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:PlanExerciseRow">
                                <Grid Padding="0,0,0,10">
                                    <controls:ExerciseCardView
                                        ExerciseName="{Binding ExerciseName}"
                                        ImageUrl="{Binding ImageUrl}"
                                        Order="{Binding Order}"
                                        ShowOrder="True"
                                        SetsPlanned="{Binding Exercise.SetsPlanned}"
                                        RepsPlanned="{Binding Exercise.RepsPlanned}"
                                        ShowSetsReps="True"
                                        IsSelected="False"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <BoxView HeightRequest="16" Color="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── ACTION BAR ── -->
        <Grid Grid.Row="2"
              Padding="20,12,20,36"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">
            <BoxView Style="{StaticResource Divider}"
                     VerticalOptions="Start" Margin="0,-12,0,0"/>
            <Button Text="{local:Localize ManageExercises}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddExerciseCommand}"
                    Margin="0,12,0,0"/>
        </Grid>

    </Grid>
</ContentPage>