<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Home.ViewModels"
             xmlns:models="clr-namespace:LevelUp.Mobile.Features.Home.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
             xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
             x:Class="LevelUp.Mobile.Features.Home.Pages.HomePage"
             x:DataType="vm:HomeViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- Saludo -->
            <VerticalStackLayout Spacing="4">
                <Label Text="{Binding Greeting, StringFormat='{0},'}"
                       Style="{StaticResource CaptionLabel}"/>
                <Label Text="{Binding UserName}"
                       Style="{StaticResource TitleLabel}"/>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"/>

            <!-- Sin plan activo -->
            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding HasNoPlan}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{x:Static constants:FA.Dumbbell}"
                           FontFamily="FASolid" FontSize="40"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize NoActivePlan}"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize NoActivePlanSub}"
                           Style="{StaticResource BodyLabel}"
                           HorizontalTextAlignment="Center"/>
                    <Button Text="{local:Localize CreatePlan}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,8,0,0"
                            Command="{Binding CreatePlanCommand}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Día de descanso -->
            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding HasRestDay}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{x:Static constants:FA.Moon}"
                           FontFamily="FASolid" FontSize="40"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize RestDay}"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="{local:Localize RestDaySub}"
                           Style="{StaticResource BodyLabel}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Día configurado pero sin ejercicios -->
            <VerticalStackLayout
                Spacing="8"
                HorizontalOptions="Center"
                IsVisible="{Binding HasDayWithNoExercises}"
                Margin="0,24,0,0">
                <Label Text="{x:Static constants:FA.Dumbbell}"
                       FontFamily="FASolid" FontSize="40"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="{local:Localize NoExercisesToday}"
                       Style="{StaticResource SubtitleLabel}"
                       HorizontalOptions="Center"/>
                <Label Text="{local:Localize NoExercisesTodaySub}"
                       Style="{StaticResource BodyLabel}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Plan de hoy -->
            <VerticalStackLayout Spacing="16"
                                 IsVisible="{Binding IsWorkoutVisible}">

                <VerticalStackLayout Spacing="2">
                    <Label Text="{local:Localize TodayPlanCaption}"
                           Style="{StaticResource CaptionLabel}"/>
                    <Label Text="{Binding TodayPlan.PlanName}"
                           Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="{Binding TodayPlan.DayName}"
                           Style="{StaticResource BodyLabel}"/>
                </VerticalStackLayout>

                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding TodayPlan.Exercises}"
                    Spacing="12">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:TodayExerciseDto">
                            <Border Style="{StaticResource CardBorder}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource Primary}"
                                            StrokeShape="Ellipse"
                                            WidthRequest="36" HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding Order}"
                                               TextColor="White"
                                               FontAttributes="Bold" FontSize="14"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding ExerciseName}"
                                               Style="{StaticResource SubtitleLabel}"
                                               FontSize="15"/>
                                        <HorizontalStackLayout Spacing="12">
                                            <Label IsVisible="{Binding SetsPlanned,
                                                       Converter={StaticResource IsNotNullConverter}}"
                                                   Style="{StaticResource CaptionLabel}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding SetsPlanned}"
                                                              TextColor="{StaticResource Primary}"
                                                              FontAttributes="Bold"/>
                                                        <Span Text=" "/>
                                                        <Span Text="{local:Localize Sets}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label IsVisible="{Binding RepsPlanned,
                                                       Converter={StaticResource IsNotNullConverter}}"
                                                   Style="{StaticResource CaptionLabel}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding RepsPlanned}"
                                                              TextColor="{StaticResource Primary}"
                                                              FontAttributes="Bold"/>
                                                        <Span Text=" "/>
                                                        <Span Text="{local:Localize Reps}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="{local:Localize StartWorkout}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartWorkoutCommand}"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>