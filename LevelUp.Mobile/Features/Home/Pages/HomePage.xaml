<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Home.ViewModels"
             xmlns:models="clr-namespace:LevelUp.Mobile.Features.Home.Models"
             xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
             xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
             xmlns:controls="clr-namespace:LevelUp.Mobile.Shared.Controls"
             x:Class="LevelUp.Mobile.Features.Home.Pages.HomePage"
             x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="20,16,20,14"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">

            <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenSettingsCommand}"/>
                </HorizontalStackLayout.GestureRecognizers>
                <Border WidthRequest="38" HeightRequest="38" StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}">
                    <Border.StrokeShape>
                        <Ellipse/>
                    </Border.StrokeShape>
                    <Grid>
                        <Label Text="{Binding UserName, Converter={StaticResource InitialsConverter}}"
                               TextColor="White" FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               IsVisible="{Binding ProfilePictureUrl, Converter={StaticResource IsNullConverter}}"/>
                        <Image Source="{Binding ProfilePictureUrl}" Aspect="AspectFill"
                               IsVisible="{Binding ProfilePictureUrl, Converter={StaticResource IsNotNullConverter}}"/>
                    </Grid>
                </Border>
                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                    <Label Text="{Binding Greeting}" FontSize="11"
                           TextColor="{AppThemeBinding
                               Light={StaticResource TextPrimaryLight},
                               Dark={StaticResource TextPrimaryDark}}"/>
                    <Label Text="{Binding UserName}" FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding
                               Light={StaticResource TextSecondaryLight},
                               Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Image Grid.Column="2" Source="appiconfg.svg"
                   HeightRequest="34" WidthRequest="34"
                   VerticalOptions="Center" HorizontalOptions="End"/>

            <BoxView Grid.ColumnSpan="3" Style="{StaticResource Divider}" VerticalOptions="End"/>
        </Grid>

        <!-- ── CONTENIDO ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="24">

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" HorizontalOptions="Center"/>

                <!-- Sin plan activo -->
                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasNoPlan}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="{x:Static constants:FA.Dumbbell}"
                               FontFamily="FASolid" FontSize="40"
                               TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                        <Label Text="{local:Localize NoActivePlan}"
                               Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center"/>
                        <Label Text="{local:Localize NoActivePlanSub}"
                               Style="{StaticResource BodyLabel}" HorizontalTextAlignment="Center"/>
                        <Button Text="{local:Localize CreatePlan}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,8,0,0" Command="{Binding CreatePlanCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Día de descanso -->
                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasRestDay}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="{x:Static constants:FA.Moon}"
                               FontFamily="FASolid" FontSize="40"
                               TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                        <Label Text="{local:Localize RestDay}"
                               Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center"/>
                        <Label Text="{local:Localize RestDaySub}"
                               Style="{StaticResource BodyLabel}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Sin ejercicios para hoy -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center"
                                     IsVisible="{Binding HasDayWithNoExercises}"
                                     Margin="0,24,0,0">
                    <Label Text="{x:Static constants:FA.Dumbbell}"
                           FontFamily="FASolid" FontSize="40"
                           TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                    <Label Text="{local:Localize NoExercisesToday}"
                           Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center"/>
                    <Label Text="{local:Localize NoExercisesTodaySub}"
                           Style="{StaticResource BodyLabel}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- ── Plan de hoy ── -->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding IsWorkoutVisible}">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{local:Localize TodayPlanCaption}" Style="{StaticResource CaptionLabel}"/>
                        <Label Text="{Binding TodayPlan.PlanName}" Style="{StaticResource SubtitleLabel}"/>
                        <Label Text="{Binding TodayPlan.DayName}" Style="{StaticResource BodyLabel}"/>
                    </VerticalStackLayout>

                    <!-- CollectionView agrupado por grupo muscular, 2 columnas -->
                    <CollectionView ItemsSource="{Binding ExerciseGroups}"
                                    IsGrouped="True"
                                    SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="2"
                                             HorizontalItemSpacing="10"
                                             VerticalItemSpacing="0"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="models:TodayExerciseGroup">
                                <Label Text="{Binding MuscleGroupName}"
                                       FontSize="12" FontAttributes="Bold"
                                       CharacterSpacing="1.2"
                                       Margin="2,12,0,6"
                                       TextColor="{AppThemeBinding
                                           Light={StaticResource TextDisabledLight},
                                           Dark={StaticResource TextDisabledDark}}"/>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TodayExerciseDto">
                                <Grid Padding="0,0,0,10">
                                    <controls:ExerciseCardView
                                        ExerciseName="{Binding ExerciseName}"
                                        ImageUrl="{Binding ImageUrl}"
                                        Order="{Binding Order}"
                                        ShowOrder="True"
                                        SetsPlanned="{Binding SetsPlanned}"
                                        RepsPlanned="{Binding RepsPlanned}"
                                        ShowSetsReps="True"
                                        IsSelected="False"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── ACTION BAR fijo abajo ── -->
        <Grid Grid.Row="2"
              Padding="20,12,20,36"
              IsVisible="{Binding IsWorkoutVisible}"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">
            <BoxView Style="{StaticResource Divider}"
                     VerticalOptions="Start" Margin="0,-12,0,0"/>
            <Button Text="{local:Localize StartWorkout}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding StartWorkoutCommand}"
                    Margin="0,12,0,0"/>
        </Grid>

    </Grid>
</ContentPage>