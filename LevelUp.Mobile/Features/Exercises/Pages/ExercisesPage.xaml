<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Exercises.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Features.Exercises.Models"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    xmlns:controls="clr-namespace:LevelUp.Mobile.Shared.Controls"
    x:Class="LevelUp.Mobile.Features.Exercises.Pages.ExercisesPage"
    x:DataType="vm:ExercisesViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 0 — HEADER                                            -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="20,56,20,16"
              BackgroundColor="{AppThemeBinding
                  Light={StaticResource SurfaceLight},
                  Dark={StaticResource SurfaceDark}}">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="{local:Localize Exercises}"
                       Style="{StaticResource TitleLabel}"/>
                <!-- Contador de resultados -->
                <Label FontSize="13"
                       TextColor="{AppThemeBinding
                           Light={StaticResource TextSecondaryLight},
                           Dark={StaticResource TextSecondaryDark}}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding TotalCount}"/>
                            <Span Text=" "/>
                            <Span Text="{local:Localize ExercisesFound}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>

            <!-- Botón filtros activos (badge) -->
            <Border Grid.Column="1"
                    Padding="12,8"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    BackgroundColor="{AppThemeBinding
                        Light={StaticResource SurfaceElevatedLight},
                        Dark={StaticResource SurfaceElevatedDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleFiltersCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="{x:Static constants:FA.Sliders}"
                           FontFamily="FASolid" FontSize="14"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                    <Label Text="{local:Localize Filters}"
                           FontSize="13" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding
                               Light={StaticResource TextPrimaryLight},
                               Dark={StaticResource TextPrimaryDark}}"/>
                    <!-- Badge con cantidad de filtros activos -->
                    <Border Padding="5,2"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            IsVisible="{Binding ActiveFilterCount,
                                Converter={StaticResource IntGreaterThanZeroBoolConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding ActiveFilterCount}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 1 — BARRA DE BÚSQUEDA                                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Margin="20,0,20,0"
                Padding="14,0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding
                    Light={StaticResource SurfaceElevatedLight},
                    Dark={StaticResource SurfaceElevatedDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="{x:Static constants:FA.MagnifyingGlass}"
                       FontFamily="FASolid" FontSize="14"
                       TextColor="{AppThemeBinding
                           Light={StaticResource TextDisabledLight},
                           Dark={StaticResource TextDisabledDark}}"
                       VerticalOptions="Center"/>
                <Entry Grid.Column="1"
                       Text="{Binding SearchText}"
                       Placeholder="{local:Localize SearchExercises}"
                       BackgroundColor="Transparent"
                       FontSize="14"
                       HeightRequest="46"/>
                <Label Grid.Column="2"
                       Text="{x:Static constants:FA.Xmark}"
                       FontFamily="FASolid" FontSize="14"
                       TextColor="{AppThemeBinding
                           Light={StaticResource TextDisabledLight},
                           Dark={StaticResource TextDisabledDark}}"
                       VerticalOptions="Center"
                       IsVisible="{Binding SearchText,
                           Converter={StaticResource StringNotNullOrEmptyBoolConverter}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ClearSearchCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 2 — CHIPS GRUPO MUSCULAR                              -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="0,10,0,0"
                    Padding="20,0">
            <HorizontalStackLayout Spacing="8"
                                   BindableLayout.ItemsSource="{Binding MuscleGroups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MuscleGroupChip">
                        <Border Padding="14,7"
                                StrokeThickness="1.5"
                                BackgroundColor="{AppThemeBinding
                                    Light={StaticResource SurfaceLight},
                                    Dark={StaticResource SurfaceElevatedDark}}"
                                Stroke="{AppThemeBinding
                                    Light={StaticResource DividerLight},
                                    Dark={StaticResource DividerDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Name}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource TextSecondaryLight},
                                       Dark={StaticResource TextSecondaryDark}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                    <Setter Property="BackgroundColor" Value="#1AFF6B00"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="Stroke" Value="{AppThemeBinding
                                        Light={StaticResource DividerLight},
                                        Dark={StaticResource DividerDark}}"/>
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding
                                        Light={StaticResource SurfaceLight},
                                        Dark={StaticResource SurfaceElevatedDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                        Path=BindingContext.SelectGroupCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 3 — PANEL FILTROS EXPANDIBLE                          -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Margin="20,10,20,0"
                StrokeThickness="0"
                Padding="16"
                IsVisible="{Binding IsFiltersExpanded}"
                BackgroundColor="{AppThemeBinding
                    Light={StaticResource SurfaceLight},
                    Dark={StaticResource CardDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="14">

                <!-- Tipo de ejercicio -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="{local:Localize ExerciseType}"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding
                               Light={StaticResource TextSecondaryLight},
                               Dark={StaticResource TextSecondaryDark}}"/>
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding ExerciseTypeFilters}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FilterChip">
                                <Border Padding="12,6"
                                        StrokeThickness="1.5"
                                        Stroke="{AppThemeBinding
                                            Light={StaticResource DividerLight},
                                            Dark={StaticResource DividerDark}}"
                                        BackgroundColor="{AppThemeBinding
                                            Light={StaticResource SurfaceElevatedLight},
                                            Dark={StaticResource SurfaceElevatedDark}}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="{Binding Icon}"
                                               FontFamily="FASolid" FontSize="11"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Text="{Binding Label}"
                                               FontSize="12" FontAttributes="Bold"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                            <Setter Property="BackgroundColor" Value="#1AFF6B00"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.ToggleTypeFilterCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <BoxView Style="{StaticResource Divider}"/>

                <!-- Incluye peso corporal -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{local:Localize IncludesBodyweight}"
                               FontSize="14" FontAttributes="Bold"/>
                        <Label Text="{local:Localize IncludesBodyweightDesc}"
                               FontSize="12"
                               TextColor="{AppThemeBinding
                                   Light={StaticResource TextSecondaryLight},
                                   Dark={StaticResource TextSecondaryDark}}"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding FilterBodyweight}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center"/>
                </Grid>

                <BoxView Style="{StaticResource Divider}"/>

                <!-- Botón limpiar filtros -->
                <Button Text="{local:Localize ClearAllFilters}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearAllFiltersCommand}"
                        HeightRequest="38"
                        FontSize="13"
                        IsVisible="{Binding ActiveFilterCount,
                            Converter={StaticResource IntGreaterThanZeroBoolConverter}}"/>

            </VerticalStackLayout>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 4 — LISTA DE EJERCICIOS                               -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,10,0,0">

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}"
                HorizontalOptions="Center"
                VerticalOptions="Center"/>

            <!-- Empty state -->
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12"
                IsVisible="{Binding IsEmpty}">
                <Label Text="{x:Static constants:FA.MagnifyingGlass}"
                       FontFamily="FASolid" FontSize="48"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="{local:Localize NoExercisesFound}"
                       Style="{StaticResource SubtitleLabel}"
                       HorizontalOptions="Center"/>
                <Label Text="{local:Localize TryOtherFilters}"
                       Style="{StaticResource BodyLabel}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Cards 2 por fila -->
            <CollectionView
                ItemsSource="{Binding FilteredExercises}"
                SelectionMode="None"
                IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                Margin="12,0,12,0"
                RemainingItemsThreshold="10"
                RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="8"
                                     VerticalItemSpacing="8"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ExerciseRow">
                        <Grid Padding="4">
                            <!-- Card del ejercicio -->
                            <Border Style="{StaticResource CardBorder}"
                                    Padding="0">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="0">

                                    <!-- Imagen / placeholder -->
                                    <Grid Grid.Row="0"
                                          HeightRequest="110"
                                          BackgroundColor="{AppThemeBinding
                                              Light={StaticResource SurfaceElevatedLight},
                                              Dark={StaticResource SurfaceElevatedDark}}">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding HasImage}"/>
                                        <!-- Icono placeholder si no hay imagen -->
                                        <Label Text="{x:Static constants:FA.Dumbbell}"
                                               FontFamily="FASolid" FontSize="32"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextDisabledLight},
                                                   Dark={StaticResource TextDisabledDark}}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding HasImage,
                                                   Converter={StaticResource InvertedBoolConverter}}"/>

                                        <!-- Badge de tipo de ejercicio -->
                                        <Border Margin="8"
                                                Padding="7,3"
                                                StrokeThickness="0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                BackgroundColor="#CC000000">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding TypeIcon}"
                                                   FontFamily="FASolid" FontSize="10"
                                                   TextColor="White"/>
                                        </Border>
                                    </Grid>

                                    <!-- Nombre y músculos -->
                                    <VerticalStackLayout Grid.Row="1"
                                                         Padding="12,10,12,12"
                                                         Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="13" FontAttributes="Bold"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding PrimaryMuscles}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>

                            <!-- Tap gesture sobre toda la card -->
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                        Path=BindingContext.OpenDetailCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <!-- Spinner de "load more" -->
                    <ActivityIndicator
                        IsRunning="{Binding IsLoadingMore}"
                        IsVisible="{Binding IsLoadingMore}"
                        Color="{StaticResource Primary}"
                        Margin="0,8,0,24"
                        HorizontalOptions="Center"/>
                </CollectionView.Footer>

            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>
