<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LevelUp.Mobile.Features.Exercises.ViewModels"
    xmlns:models="clr-namespace:LevelUp.Mobile.Features.Exercises.Models"
    xmlns:constants="clr-namespace:LevelUp.Mobile.Core.Constants"
    xmlns:local="clr-namespace:LevelUp.Mobile.Core.Extensions"
    x:Class="LevelUp.Mobile.Features.Exercises.Pages.ExerciseDetailPage"
    x:DataType="vm:ExerciseDetailViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*">

        <!-- LOADING STATE -->
        <ActivityIndicator
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Primary}"
            HorizontalOptions="Center"
            VerticalOptions="Center"/>

        <!-- CONTENIDO PRINCIPAL -->
        <ScrollView IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- IMAGEN HERO + HEADER OVERLAY                       -->
                <!-- ═══════════════════════════════════════════════════ -->
                <Grid HeightRequest="280">

                    <!-- Imagen de fondo -->
                    <Image Source="{Binding Detail.ImageUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding Detail.HasImage}"/>

                    <!-- Placeholder si no hay imagen -->
                    <Grid BackgroundColor="{AppThemeBinding
                              Light={StaticResource SurfaceElevatedLight},
                              Dark={StaticResource SurfaceElevatedDark}}"
                          IsVisible="{Binding Detail.HasImage,
                              Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="{x:Static constants:FA.Dumbbell}"
                               FontFamily="FASolid" FontSize="64"
                               TextColor="{AppThemeBinding
                                   Light={StaticResource TextDisabledLight},
                                   Dark={StaticResource TextDisabledDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Gradiente bottom-up -->
                    <BoxView VerticalOptions="Fill" HeightRequest="280">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.3"/>
                                <GradientStop Color="#CC000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Botón Back -->
                    <Border Margin="20,52,0,0"
                            Padding="10"
                            StrokeThickness="0"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            BackgroundColor="#80000000">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static constants:FA.AngleLeft}"
                               FontFamily="FASolid" FontSize="18"
                               TextColor="White"/>
                    </Border>

                    <!-- Nombre + badges (bottom) -->
                    <VerticalStackLayout VerticalOptions="End"
                                         Padding="20,0,20,18"
                                         Spacing="6">

                        <HorizontalStackLayout Spacing="6">

                            <!-- Badge tipo ejercicio -->
                            <Border Padding="8,4"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Primary}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding Detail.TypeIcon}"
                                           FontFamily="FASolid" FontSize="11"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                    <Label Text="{Binding Detail.TypeLabel}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Badge peso corporal -->
                            <Border Padding="8,4"
                                    StrokeThickness="0"
                                    BackgroundColor="#80FFFFFF"
                                    IsVisible="{Binding Detail.IncludesBodyWeight}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{x:Static constants:FA.PersonRunning}"
                                           FontFamily="FASolid" FontSize="11"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                    <Label Text="{local:Localize Bodyweight}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                        </HorizontalStackLayout>

                        <Label Text="{Binding Detail.Name}"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="White"
                               LineBreakMode="WordWrap"/>

                    </VerticalStackLayout>
                </Grid>

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- CUERPO DEL DETALLE                                 -->
                <!-- ═══════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="20,20,20,40" Spacing="20">

                    <!-- ── MÚSCULOS INVOLUCRADOS ─────────────────────── -->
                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="14">

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{x:Static constants:FA.PersonArmsOut}"
                                       FontFamily="FASolid" FontSize="14"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center"/>
                                <Label Text="{local:Localize MusclesInvolved}"
                                       Style="{StaticResource SubtitleLabel}"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <BoxView Style="{StaticResource Divider}"/>

                            <!-- Empty state -->
                            <Label Text="{local:Localize NoMuscleData}"
                                   Style="{StaticResource BodyLabel}"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding Detail.HasMuscles,
                                       Converter={StaticResource InvertedBoolConverter}}"/>

                            <!-- Grupos por rol -->
                            <VerticalStackLayout Spacing="12"
                                                 IsVisible="{Binding Detail.HasMuscles}"
                                                 BindableLayout.ItemsSource="{Binding Detail.MuscleRoles}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:MuscleRoleGroup">
                                        <VerticalStackLayout Spacing="8">

                                            <!-- Encabezado de rol -->
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding RoleIcon}"
                                                       FontFamily="FASolid" FontSize="12"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding RoleLabel}"
                                                       FontSize="12" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding
                                                           Light={StaticResource TextSecondaryLight},
                                                           Dark={StaticResource TextSecondaryDark}}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>

                                            <!-- Chips de músculos -->
                                            <FlexLayout Wrap="Wrap"
                                                        Direction="Row"
                                                        JustifyContent="Start"
                                                        BindableLayout.ItemsSource="{Binding MuscleNames}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <Border Margin="0,0,6,6"
                                                                Padding="10,5"
                                                                StrokeThickness="1"
                                                                Stroke="{AppThemeBinding
                                                                    Light={StaticResource DividerLight},
                                                                    Dark={StaticResource DividerDark}}"
                                                                BackgroundColor="{AppThemeBinding
                                                                    Light={StaticResource SurfaceElevatedLight},
                                                                    Dark={StaticResource SurfaceElevatedDark}}">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="20"/>
                                                            </Border.StrokeShape>
                                                            <Label Text="{Binding .}"
                                                                   FontSize="12"
                                                                   TextColor="{AppThemeBinding
                                                                       Light={StaticResource TextPrimaryLight},
                                                                       Dark={StaticResource TextPrimaryDark}}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </FlexLayout>

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── INSTRUCCIONES ─────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{x:Static constants:FA.ListOl}"
                                       FontFamily="FASolid" FontSize="14"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center"/>
                                <Label Text="{local:Localize Instructions}"
                                       Style="{StaticResource SubtitleLabel}"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <BoxView Style="{StaticResource Divider}"/>
                            <Label Text="{Binding Detail.Instructions}"
                                   FontSize="14"
                                   LineHeight="1.6"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource TextPrimaryLight},
                                       Dark={StaticResource TextPrimaryDark}}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── TIPS ──────────────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}"
                            IsVisible="{Binding Detail.HasTips}">
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{x:Static constants:FA.Lightbulb}"
                                       FontFamily="FASolid" FontSize="14"
                                       TextColor="{StaticResource Warning}"
                                       VerticalOptions="Center"/>
                                <Label Text="{local:Localize Tips}"
                                       Style="{StaticResource SubtitleLabel}"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <BoxView Style="{StaticResource Divider}"/>
                            <Label Text="{Binding Detail.Tips}"
                                   FontSize="14"
                                   LineHeight="1.6"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource TextPrimaryLight},
                                       Dark={StaticResource TextPrimaryDark}}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── ERRORES COMUNES ────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}"
                            IsVisible="{Binding Detail.HasCommonMistakes}">
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{x:Static constants:FA.TriangleExclamation}"
                                       FontFamily="FASolid" FontSize="14"
                                       TextColor="{StaticResource Error}"
                                       VerticalOptions="Center"/>
                                <Label Text="{local:Localize CommonMistakes}"
                                       Style="{StaticResource SubtitleLabel}"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <BoxView Style="{StaticResource Divider}"/>
                            <Label Text="{Binding Detail.CommonMistakes}"
                                   FontSize="14"
                                   LineHeight="1.6"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource TextPrimaryLight},
                                       Dark={StaticResource TextPrimaryDark}}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── INFO TÉCNICA (bodyweight) ─────────────────── -->
                    <Border Style="{StaticResource CardBorder}"
                            IsVisible="{Binding Detail.IncludesBodyWeight}">
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{x:Static constants:FA.WeightScale}"
                                       FontFamily="FASolid" FontSize="14"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center"/>
                                <Label Text="{local:Localize BodyweightInfo}"
                                       Style="{StaticResource SubtitleLabel}"
                                       FontSize="16"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <BoxView Style="{StaticResource Divider}"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                                <!-- Factor -->
                                <Border Grid.Column="0"
                                        Padding="14,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding
                                            Light={StaticResource SurfaceElevatedLight},
                                            Dark={StaticResource SurfaceElevatedDark}}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{local:Localize BodyweightFactor}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}"/>
                                        <Label Text="{Binding Detail.BodyWeightFactor, StringFormat='{0:P0}'}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"/>
                                        <Label Text="{local:Localize OfYourWeight}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Tipo -->
                                <Border Grid.Column="1"
                                        Padding="14,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding
                                            Light={StaticResource SurfaceElevatedLight},
                                            Dark={StaticResource SurfaceElevatedDark}}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{local:Localize ExerciseType}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}"/>
                                        <Label Text="{Binding Detail.TypeIcon}"
                                               FontFamily="FASolid" FontSize="20"
                                               TextColor="{StaticResource Primary}"/>
                                        <Label Text="{Binding Detail.TypeLabel}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding
                                                   Light={StaticResource TextSecondaryLight},
                                                   Dark={StaticResource TextSecondaryDark}}"/>
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
